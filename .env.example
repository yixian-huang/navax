# 本地访问地址；生产环境必须改为真实 HTTPS 地址，且不要以 / 结尾。
PUBLIC_BASE_URL=http://localhost:8080
NAVAX_SECURE_COOKIES=false

INSTANCE_NAME=nav.ax
# 启用用户子域名时填写根域名；官方实例使用 nav.ax，自托管实例填写自己的域名。
ROOT_DOMAIN=

# 首次初始化令牌。生产环境请执行 `openssl rand -hex 32` 后填入。
# 留空时应用会在启动时随机生成，并仅在尚未初始化时写入容器日志。
NAVAX_SETUP_TOKEN=

# 加密第三方服务凭据的 32 字节 Base64 密钥，建议生产环境配置：
# openssl rand -base64 32
NAVAX_MASTER_KEY=

NAVAX_SESSION_TTL=720h
NAVAX_SHUTDOWN_TIMEOUT=15s

# 可选：签名更新清单。容器部署只能检查更新，升级由 Docker Compose 完成。
NAVAX_UPDATE_MANIFEST_URL=
NAVAX_UPDATE_PUBLIC_KEY=

# Compose 主机端口与镜像，可按需覆盖。
NAVAX_PORT=8080
NAVAX_IMAGE=ghcr.io/yixian-huang/navax:latest

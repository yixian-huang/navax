# nav.ax 生产环境示例（官方域名 nav.ax）。
# 复制为 .env 后，填入下方标注为“必填”的密钥；自托管者把 nav.ax 换成自己的域名。
# 完整说明见 docs/deployment.md。

# 对外 HTTPS 地址，不以 / 结尾。用于 Origin 校验、HSTS、Cookie Secure、发布快照 canonical。
PUBLIC_BASE_URL=https://nav.ax
INSTANCE_NAME=nav.ax

# 启用用户子域名时填写根域名；用户子域名形如 name.nav.ax。需先在 DNS 添加 *.nav.ax 通配记录。
ROOT_DOMAIN=nav.ax

# 挂在 TLS 反代之后：会话 Cookie 加 Secure。
NAVAX_SECURE_COOKIES=true

# 反代可信来源（逗号分隔 CIDR/IP，含 Docker 网桥）。不配置则限流与统计按代理 IP 归并。
NAVAX_TRUSTED_PROXIES=127.0.0.1/32,172.16.0.0/12

# 必填：首次 /setup 初始化令牌。openssl rand -hex 32
NAVAX_SETUP_TOKEN=
# 必填并妥善备份（跨机灾备需保留同一个）：openssl rand -base64 32
NAVAX_MASTER_KEY=

NAVAX_SESSION_TTL=720h
NAVAX_SHUTDOWN_TIMEOUT=15s

# 可选：签名更新清单。容器部署只能检查更新，升级由 Docker Compose 完成。
NAVAX_UPDATE_MANIFEST_URL=
NAVAX_UPDATE_PUBLIC_KEY=

# Compose 主机端口与镜像。生产建议固定到具体版本/摘要而非 :latest。
NAVAX_PORT=8080
NAVAX_IMAGE=ghcr.io/yixian-huang/navax:latest
